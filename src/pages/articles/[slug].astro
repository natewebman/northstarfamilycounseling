---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { getArticles, getArticleBySlug } from '../../lib/supabase';

// Static paths for SSG — fetches all published article slugs at build time
export async function getStaticPaths() {
  const articles = await getArticles();
  return articles.map((article: any) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = await getArticleBySlug(slug as string);

if (!article) {
  return Astro.redirect('/articles');
}
---

<BaseLayout
  title={`${article.title} | North Star Counseling Frisco, TX`}
  description={article.meta_description || `${article.title} - Expert insights from North Star Specialty Counseling & Therapy in Frisco, Texas.`}
>

  <article class="py-20 lg:py-28">
    <div class="container mx-auto px-4 max-w-3xl">
      <!-- Article Header -->
      <header class="mb-12 text-center animate-fade-up">
        {article.category && (
          <a
            href={`/articles`}
            class="text-navy/60 font-semibold tracking-wider uppercase text-sm mb-4 block hover:text-navy transition-colors"
          >
            {article.category}
          </a>
        )}
        <h1 class="text-4xl md:text-5xl font-serif font-bold text-navy mb-6 leading-tight">
          {article.title}
        </h1>
        {article.published_at && (
          <time class="text-slate text-sm" datetime={article.published_at}>
            {new Date(article.published_at).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        )}
      </header>

      <!-- Article Body -->
      <div
        class="prose prose-lg prose-slate max-w-none
          prose-headings:font-serif prose-headings:text-navy
          prose-a:text-navy prose-a:underline prose-a:decoration-navy/30 hover:prose-a:decoration-navy
          prose-strong:text-navy
          prose-img:rounded-2xl"
        set:html={article.content}
      />

      <!-- Back to articles -->
      <div class="mt-16 pt-8 border-t border-navy/10">
        <a
          href="/articles"
          class="text-navy font-medium flex items-center gap-2 hover:gap-3 transition-all"
        >
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Back to all articles
        </a>
      </div>
    </div>
  </article>

  <CTASection
    heading="Need Support?"
    text="If this article resonated with you, our clinical team is here to help. Schedule a free 15-minute consultation to discuss how therapy can support your journey."
    primaryLabel="Book Your Free Consultation"
    secondaryLabel=""
  />

</BaseLayout>
