---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const bookingUrl = 'https://northstarfrisco.com/?utm_campaign=nscounselingandtherapy';

const credentials = [
  'Licensed to provide therapy in Texas and Minnesota',
  'Perinatal Mental Health Certified',
  'Specializing in postpartum, burnout, and family systems',
];
---

<BaseLayout
  title="About North Star Specialty Counseling in Frisco, Texas | Contact Us"
  description="Meet Megan Corrieri, clinical therapist and founder of North Star Specialty Counseling in Frisco, TX. Licensed in Texas and Minnesota."
>

  <!-- Hero -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="container mx-auto px-4 max-w-4xl text-center animate-fade-up">
      <span class="text-navy/60 font-semibold tracking-wider uppercase text-sm mb-4 block">
        Our Frisco Counseling Team
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-navy mb-6 leading-tight">
        About North Star Specialty Counseling in Frisco, Texas
      </h1>
    </div>
  </section>

  <!-- Bio Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="animate-on-scroll fade-up">
        <h2 class="text-3xl font-serif font-bold text-navy mb-2">
          Megan Corrieri
        </h2>
        <p class="text-navy/60 font-medium mb-8">Clinical Therapist & Founder</p>
        <div class="space-y-6 text-slate text-lg leading-relaxed">
          <p>
            I believe that therapy is a collaborative process. My approach is warm, direct, and deeply rooted in clinical expertise. I chose to establish North Star in Frisco because I deeply understand the unique pressures of this community—the drive for excellence, the fast-paced lifestyle, and the hidden toll it can take on individuals and families.
          </p>
          <p>
            With extensive experience in perinatal mental health, burnout recovery, and systemic family therapy, I provide a safe container for you to explore your experiences, understand your nervous system, and create meaningful change. We don't just treat symptoms; we look at the whole picture of your life to foster genuine resilience.
          </p>
        </div>
        <div class="mt-10 flex flex-wrap gap-3">
          {credentials.map((cred) => (
            <span class="inline-flex items-center gap-2 bg-navy/5 text-navy text-sm font-medium px-4 py-2 rounded-full">
              <svg class="w-4 h-4 text-navy/60 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
              {cred}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 bg-navy text-cream">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-white mb-12">
        Contact North Star Therapy in Frisco, TX
      </h2>
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="bg-white/10 p-8 rounded-2xl border border-white/10">
          <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-cream" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">In-Person Therapy</h3>
          <p class="text-cream/70">
            Physical location in Frisco, Texas. Providing a calm, confidential space for local clients to disconnect from the daily rush.
          </p>
        </div>
        <div class="bg-white/10 p-8 rounded-2xl border border-white/10">
          <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-cream" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
              <line x1="8" y1="21" x2="16" y2="21"></line>
              <line x1="12" y1="17" x2="12" y2="21"></line>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Telehealth Services</h3>
          <p class="text-cream/70">
            Secure, HIPAA-compliant online therapy available for clients in Texas and Minnesota who need flexible scheduling.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    heading="Ready to begin?"
    text="All scheduling and consultations are handled through our secure client portal. Click below to view availability and book your initial consultation."
    primaryLabel="Get a Free 15-Minute Consultation"
    secondaryLabel=""
    variant="white"
  />

</BaseLayout>
