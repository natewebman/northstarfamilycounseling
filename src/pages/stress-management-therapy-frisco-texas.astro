---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const bookingUrl = 'https://northstarfrisco.com/?utm_campaign=nscounselingandtherapy';

const symptoms = [
  {
    title: 'Depleted Reserves',
    desc: "Waking up exhausted, relying on caffeine and adrenaline to push through the day, and crashing hard on the weekends.",
    icon: '<rect x="2" y="6" width="6" height="14" rx="2"/><rect x="10" y="2" width="6" height="18" rx="2" opacity="0.3"/><rect x="18" y="10" width="4" height="10" rx="1" opacity="0.15"/>',
  },
  {
    title: 'Cognitive Overload',
    desc: 'Brain fog, difficulty making simple decisions, perfectionism paralysis, and feeling constantly distracted or detached.',
    icon: '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/>',
  },
  {
    title: 'Dysregulation',
    desc: "A nervous system stuck in 'fight or flight', leading to short tempers, anxiety, insomnia, or chronic physical tension.",
    icon: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
  },
];

const approaches = [
  'Identify and map your unique nervous system states and triggers.',
  'Develop somatic (body-based) tools for immediate regulation during high-stress moments.',
  'Address the underlying perfectionism, people-pleasing, or boundary issues driving the burnout cycle.',
  'Create sustainable rhythms for work, parenting, and genuine rest.',
];
---

<BaseLayout
  title="Stress Management & Burnout Recovery in Frisco, TX | North Star"
  description="Stress management and burnout recovery therapy in Frisco, Texas. Evidence-based counseling for professionals and families. North Star Specialty Counseling."
>

  <!-- Hero Section -->
  <section class="py-24 lg:py-32 bg-navy text-cream relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"></div>
    <div class="container mx-auto px-4 max-w-4xl text-center relative z-10">
      <div class="animate-fade-up">
        <span class="text-cream/70 font-semibold tracking-wider uppercase text-sm mb-4 block">
          Stress Management in Frisco, TX
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold mb-6 leading-tight text-white">
          Stress Management & Burnout Recovery in Frisco, Texas
        </h1>
        <p class="text-xl text-cream/80 leading-relaxed mb-10 max-w-2xl mx-auto">
          For high-achieving professionals and overwhelmed parents running on empty. It's time to recalibrate your nervous system.
        </p>
        <a
          href={bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-cream text-navy px-8 py-4 rounded-full text-lg font-semibold hover:bg-white transition-all shadow-lg hover:-translate-y-0.5"
        >
          Get Started Now
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Clinical Overview -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-16 animate-on-scroll fade-up">
        <h2 class="text-3xl font-serif font-bold text-navy mb-6">
          Stress Management Therapy in Frisco, TX
        </h2>
        <p class="text-lg text-slate leading-relaxed mb-6">
          Frisco is home to some of the most driven professionals and dedicated parents in Texas. The corporate pressure along the tollway corridor, combined with the demands of maintaining a high standard of living, creates a perfect storm for burnout. You might find yourself operating with a "constant on-call energy"—checking emails at 10 PM, rushing between extracurriculars, and never truly powering down.
        </p>
        <p class="text-lg text-slate leading-relaxed">
          Chronic stress isn't just "in your head"—it's a physiological state of nervous system dysregulation. When you're constantly operating in survival mode, your body loses its ability to return to a baseline of calm, leading to profound physical and emotional exhaustion.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {symptoms.map((item) => (
          <div class="animate-on-scroll fade-up bg-cream/50 p-8 rounded-2xl border border-navy/5 text-center">
            <div class="w-12 h-12 bg-navy/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-navy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={item.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-navy mb-3">{item.title}</h3>
            <p class="text-slate text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Therapeutic Approach -->
  <section class="py-20 bg-cream">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="animate-on-scroll fade-up bg-white p-10 md:p-16 rounded-3xl shadow-sm border border-navy/5">
        <h2 class="text-3xl font-serif font-bold text-navy mb-8 text-center">
          Burnout Recovery Counseling for Frisco Professionals
        </h2>
        <div class="space-y-6 text-slate text-lg leading-relaxed">
          <p>
            Recovery from burnout requires more than just "taking a bubble bath" or "practicing self-care." It requires a clinical approach to rewiring how your body and mind respond to stressors in a high-demand environment.
          </p>
          <p>
            At North Star, we utilize evidence-based modalities to help you build sustainable stress management habits:
          </p>
          <ul class="list-disc pl-6 space-y-3 text-navy/80 font-medium">
            {approaches.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
        <div class="mt-12 flex flex-col sm:flex-row justify-center gap-4">
          <a
            href={bookingUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-navy text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-navy/90 transition-all shadow-lg"
          >
            Schedule Your First Session
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
          <a
            href={bookingUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-transparent border border-navy text-navy px-8 py-4 rounded-full text-lg font-semibold hover:bg-navy/5 transition-all"
          >
            Book Your Free Consultation
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
