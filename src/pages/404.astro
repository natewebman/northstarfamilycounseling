---
import BaseLayout from '../layouts/BaseLayout.astro';

const bookingUrl = 'https://northstarfrisco.com/?utm_campaign=nscounselingandtherapy';
---

<BaseLayout title="Page Not Found | North Star Counseling">

  <section class="py-32 text-center">
    <div class="container mx-auto px-4 max-w-2xl">
      <h1 class="text-6xl font-serif font-bold text-navy mb-6">404</h1>
      <p class="text-xl text-slate mb-8">
        We couldn't find that page. Let's get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-navy text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-navy/90 transition-all shadow-lg"
        >
          Go Home
        </a>
        <a
          href={bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 border border-navy text-navy px-8 py-4 rounded-full text-lg font-semibold hover:bg-navy/5 transition-all"
        >
          Book a Consultation
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
